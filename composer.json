{
  "name": "queopius/shield",
  "description": "Queopius Shield — HTTP Security & HTTPS Hardening for Laravel",
  "type": "library",
  "homepage": "https://github.com/queopius/shield",
  "license": "MIT",
  "keywords": ["laravel", "security", "headers", "https", "csp", "hsts"],
  "authors": [
    {
      "name": "Queopius A.S.",
      "email": "dev.queopius@gmail.com",
      "role": "Desarrollador"
    }
  ],
  "support": {
    "issues": "https://github.com/queopius/shield/issues",
    "source": "https://github.com/queopius/shield",
    "docs": "https://queopius-shield.readthedocs.io/",
    "security": "https://github.com/queopius/shield/security/policy"
  },
  "funding": [
    {
      "type": "other",
      "url": "https://github.com/queopius/shield"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/contracts": "^11.0|^12.0",
    "illuminate/http": "^11.0|^12.0",
    "illuminate/routing": "^11.0|^12.0",
    "illuminate/support": "^11.0|^12.0",
    "illuminate/view": "^11.0|^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0",
    "phpunit/phpunit": "^10.5|^11.0",
    "laravel/pint": "^1.13",
    "phpstan/phpstan": "^1.11"
  },
  "autoload": {
    "psr-4": {
      "Queopius\\Shield\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Queopius\\Shield\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Queopius\\Shield\\ShieldServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "vendor/bin/pint",
    "analyse": "vendor/bin/phpstan analyse"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
